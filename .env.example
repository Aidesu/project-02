# ── Base de données (PostgreSQL) ──────────────────────────────────────────
# Chaîne de connexion Postgres (lue par Drizzle).
# Dev local via Docker :
#   docker run -d --name ds-postgres -e POSTGRES_USER=deafiaa \
#     -e POSTGRES_PASSWORD=localdev -e POSTGRES_DB=deafiaa_serv \
#     -p 5432:5432 -v ds-pgdata:/var/lib/postgresql/data postgres:17
DATABASE_URL=postgresql://deafiaa:localdev@localhost:5432/deafiaa_serv

# ── Admin (authentification) ──────────────────────────────────────────────
# Mot de passe de la page /admin (un seul administrateur).
ADMIN_PASSWORD=changez-moi
# Secret de signature des cookies de session. Générez-en un avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=remplacez-par-un-secret-aleatoire

# ── Proxmox (stats CPU / RAM) ─────────────────────────────────────────────
# URL de l'API Proxmox VE (port 8006).
PROXMOX_URL=https://192.168.1.10:8006

# Token API au format  UTILISATEUR@REALM!NOMDUTOKEN=SECRET
# Créez-le dans Proxmox : Datacenter → Permissions → API Tokens.
# Donnez au token le droit VM.Audit (lecture seule) sur les VM/conteneurs voulus.
PROXMOX_TOKEN=monitor@pve!gameservers=00000000-0000-0000-0000-000000000000

# Proxmox utilise un certificat auto-signé par défaut : mettez "true"
# pour accepter ce certificat (réseau local de confiance uniquement).
PROXMOX_INSECURE_TLS=true

# ── Téléchargements ───────────────────────────────────────────────────────
# Dossier racine des fichiers téléchargeables, hors du dépôt.
# Les fichiers sont attendus dans  DOWNLOADS_DIR/<slug>/<fichier>
# (ex. /srv/gameservers/smp-vanilla/world-saison3.zip).
DOWNLOADS_DIR=/srv/gameservers
