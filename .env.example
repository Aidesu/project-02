# ── Database (PostgreSQL) ─────────────────────────────────────────────────
# Postgres connection string (read by Drizzle).
# Local dev via Docker:
#   docker run -d --name app-postgres -e POSTGRES_USER=appuser \
#     -e POSTGRES_PASSWORD=change-me -e POSTGRES_DB=appdb \
#     -p 5432:5432 -v app-pgdata:/var/lib/postgresql/data postgres:17
DATABASE_URL=postgresql://appuser:change-me@localhost:5432/appdb

# ── Admin (authentication) ────────────────────────────────────────────────
# Password for the /admin page (single administrator).
ADMIN_PASSWORD=change-me
# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
AUTH_SECRET=replace-with-a-random-secret

# ── Proxmox (CPU / RAM stats) ─────────────────────────────────────────────
# Proxmox VE API URL (port 8006).
PROXMOX_URL=https://proxmox.example.local:8006

# API token in the format  USER@REALM!TOKENNAME=SECRET
# Create one in Proxmox: Datacenter → Permissions → API Tokens.
# Grant the token VM.Audit (read-only) on the target VMs/containers.
PROXMOX_TOKEN=monitor@pve!gameservers=00000000-0000-0000-0000-000000000000

# Proxmox uses a self-signed certificate by default: set "true"
# to accept it (trusted local network only).
PROXMOX_INSECURE_TLS=true

# ── Downloads & uploads ───────────────────────────────────────────────────
# DOWNLOADS_DIR: read-only root of files placed out-of-band, outside the repo.
# Files are expected at  DOWNLOADS_DIR/<slug>/<file>
# (e.g. /srv/gameservers/smp-vanilla/world-season3.zip).
DOWNLOADS_DIR=/srv/gameservers

# UPLOADS_DIR: writable, app-owned root for files uploaded from the admin
# (UPLOADS_DIR/<slug>/<file>). Keep it OFF the live game-server tree so the app
# never needs write access there. Uploaded files take precedence over
# same-named files in DOWNLOADS_DIR.
UPLOADS_DIR=/srv/uploads

# Max upload size in bytes (default 2 GiB if unset). Behind Cloudflare, the edge
# also caps request bodies (~100 MB on the free plan) — upload big maps via LAN.
# MAX_UPLOAD_BYTES=2147483648
