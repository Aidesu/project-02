# Environment for `docker compose`. Copy to `.env`, then fill in the secrets:
#   cp .env.docker.example .env
#
# Compose auto-loads `.env` (git-ignored). These values are injected into the
# containers at runtime — nothing here is baked into the image.

# ── PostgreSQL (bundled `db` service) ──────────────────────────────────────
# Credentials for the postgres container. Keep them in sync with DATABASE_URL.
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me
POSTGRES_DB=appdb

# Connection string used by the app and the migrate job. Inside the compose
# network the database host is the service name `db` (NOT localhost).
DATABASE_URL=postgresql://appuser:change-me@db:5432/appdb

# ── App ────────────────────────────────────────────────────────────────────
# Host port to expose the app on (container always listens on 3000).
APP_PORT=3000

# Admin login + session signing secret. Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_PASSWORD=change-me
AUTH_SECRET=random-secret

# ── Cloudflare Tunnel (HTTPS exposure via the `cloudflared` service) ────────
# Publishes the app over HTTPS without opening a port. Get the token in
# Cloudflare Zero Trust → Networks → Tunnels → create a tunnel (cloudflared) →
# copy the token from the shown install command. Then, in that tunnel, add a
# Public Hostname:  status.deafiaa.com  →  http://app:3000
# (Required by docker-compose.prod.yml; leave blank only if you remove the
#  cloudflared service.)
TUNNEL_TOKEN=

# ── Proxmox (optional — CPU/RAM stats) ─────────────────────────────────────
# Leave blank to disable. Token format: USER@REALM!TOKENNAME=SECRET
PROXMOX_URL=
PROXMOX_TOKEN=
PROXMOX_INSECURE_TLS=

# ── Downloads ──────────────────────────────────────────────────────────────
# Path INSIDE the container where downloadable files are mounted.
DOWNLOADS_DIR=/srv/gameservers
# Host directory bind-mounted (read-only) onto DOWNLOADS_DIR. Expected layout:
#   <DOWNLOADS_HOST_DIR>/<slug>/<file>
DOWNLOADS_HOST_DIR=./downloads
